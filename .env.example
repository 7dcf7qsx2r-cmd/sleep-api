# Server
PORT=8787
NODE_ENV=development

# PostgreSQL (docker-compose default)
DATABASE_URL=postgres://sleep:sleep@localhost:5432/sleep_api

# 无 Docker 时用嵌入式 PGlite（开发）
# USE_PGLITE=1
# DATABASE_URL=pglite

# JWT — change in production
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=30d

# DeepSeek (server-side only)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow 文生图（记梦分镜，服务端代理，Key 不进 App）
SILICONFLOW_API_KEY=

# Optional Sentry
SENTRY_DSN=

# Daily AI quotas (loose trial defaults)
QUOTA_GUEST_CHAT=15
QUOTA_GUEST_INTERPRET=2
QUOTA_USER_CHAT=80
QUOTA_USER_INTERPRET=10

# FCM Push Notifications
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# Worker
WORKER_POLL_INTERVAL_MS=5000

# 生物雷达厂商推送鉴权（留空=开发模式不校验）
# RADAR_PUSH_SECRET=your-vendor-push-token
