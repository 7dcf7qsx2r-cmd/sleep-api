{
  "name": "sleep-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:pglite": "USE_PGLITE=1 tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:setup:pglite": "USE_PGLITE=1 npm run db:setup",
    "smoke": "tsx scripts/smoke-p0.ts",
    "integration": "tsx scripts/integration-p0-p1.ts",
    "integration:p2": "tsx scripts/integration-p2.ts",
    "dev:docker": "bash scripts/dev-docker.sh",
    "worker": "tsx scripts/worker.ts",
    "integration:p3": "tsx scripts/integration-p3.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.2",
    "@hono/node-server": "^1.14.1",
    "@hono/zod-validator": "^0.4.3",
    "@sentry/node": "^9.15.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "hono": "^4.7.10",
    "jose": "^6.0.11",
    "pg": "^8.16.0",
    "tencentcloud-sdk-nodejs-sms": "^4.1.240",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
