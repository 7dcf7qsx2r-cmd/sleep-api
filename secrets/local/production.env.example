# 复制为 secrets/local/production.env 并填写真实值（勿提交 Git）
# 上传: ./scripts/ci/upload-github-secrets.sh production secrets/local/production.env
# SSH 私钥: cp ~/.ssh/xiaomian-txy.pem secrets/local/production.ssh && chmod 600 secrets/local/production.ssh

DATABASE_URL=postgresql://admin:PASSWORD_URL_ENCODED@172.16.0.12:5432/sleep
JWT_SECRET=replace-with-long-random-production-only
JWT_EXPIRES_IN=30d
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
SILICONFLOW_API_KEY=
SENTRY_DSN=
RADAR_PUSH_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
# 腾讯云短信（审核通过后填写；留空则 /auth/sms/send 返回 503）
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
# 生产环境勿开启 Mock
SMS_MOCK=
FCM_SERVER_KEY=
FCM_PROJECT_ID=
